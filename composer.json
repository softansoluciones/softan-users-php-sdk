{
  "name": "softan/users-php-sdk",
  "description": "SDK PHP para Softan Users — gestion de usuarios y asociaciones de aplicacion",
  "type": "library",
  "license": "MIT",
  "homepage": "https://github.com/softansoluciones/softan-users-php-sdk",
  "keywords": ["softan", "users", "sdk", "api", "usersapps"],
  "support": {
    "issues": "https://github.com/softansoluciones/softan-users-php-sdk/issues",
    "source": "https://github.com/softansoluciones/softan-users-php-sdk"
  },
  "authors": [
    { "name": "Softan Soluciones" },
    { "name": "Code Builders House" }
  ],
  "autoload": {
    "psr-4": {
      "SoftanUsers\\": "src/"
    }
  },
  "require": {
    "php": ">=8.1",
    "ext-curl": "*",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  },
  "bin": [
    "bin/install.php"
  ],
  "scripts": {
    "test": "phpunit"
  },
  "extra": {
    "branch-alias": {
      "dev-main": "0.2.x-dev"
    }
  }
}
